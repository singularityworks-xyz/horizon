{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local", "**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "lib/**", "index.ts", "index.js", "app/**"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_BETTER_AUTH_URL",
        "DATABASE_URL",
        "OPENROUTER_API_KEY",
        "OPENAI_API_KEY",
        "GEMINI_API_KEY",
        "CLOUDFLARE_R2_ACCESS_KEY_ID",
        "CLOUDFLARE_R2_SECRET_ACCESS_KEY",
        "CLOUDFLARE_R2_ACCOUNT_ID",
        "CLOUDFLARE_R2_BUCKET_NAME",
        "NODE_ENV",
        "ENABLE_ANALYTICS"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "NEXT_PUBLIC_BETTER_AUTH_URL",
        "DATABASE_URL",
        "OPENROUTER_API_KEY",
        "OPENAI_API_KEY",
        "GEMINI_API_KEY",
        "CLOUDFLARE_R2_ACCESS_KEY_ID",
        "CLOUDFLARE_R2_SECRET_ACCESS_KEY",
        "CLOUDFLARE_R2_ACCOUNT_ID",
        "CLOUDFLARE_R2_BUCKET_NAME",
        "NODE_ENV",
        "ENABLE_ANALYTICS"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "lib/**", "index.ts", "index.js", "app/**"]
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "lib/**", "index.ts", "index.js", "app/**"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "lib/**", "index.ts", "index.js", "app/**", "tsconfig.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
