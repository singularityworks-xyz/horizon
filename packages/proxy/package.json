{
  "name": "@horizon/proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Authentication proxy for Horizon web application",
  "scripts": {
    "dev": "bun --watch proxy.ts",
    "start": "bun proxy.ts",
    "build": "bun build proxy.ts --outfile dist/index.js --target node",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0",
    "http-proxy-middleware": "^2.0.6",
    "cookie-parser": "^1.4.6",
    "@horizon/db": "workspace:*",
    "@horizon/web": "workspace:*",
    "better-auth": "^1.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/cookie-parser": "^1.4.3",
    "tsx": "^4.0.0"
  }
}
