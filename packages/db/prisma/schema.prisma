// Prisma schema for Horizon
// All models are tenant-scoped for multi-tenancy isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Core tenant model - represents agencies/organizations
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  metadata  Json? // Additional tenant-specific configuration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users                  User[]
  roles                  Role[]
  clients                Client[]
  projects               Project[]
  questionnaireTemplates QuestionnaireTemplate[]
  questionnaireSubmissions QuestionnaireSubmission[]
  assets                 Asset[]
  workflows              Workflow[]
  answers                Answer[]

  @@map("tenants")
}

// User roles within a tenant
model Role {
  id        String   @id @default(cuid())
  tenantId  String
  name      String // e.g., "admin", "client", "internal"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
  @@map("roles")
}

// Users within a tenant
model User {
  id        String   @id @default(cuid())
  tenantId  String
  roleId    String
  email     String
  firstName String?
  lastName  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  tasks  Task[] // Tasks assigned to this user

  @@unique([tenantId, email])
  @@map("users")
}

// Client entities within a tenant
model Client {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  company   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects Project[]

  @@map("clients")
}

// Projects within a tenant
model Project {
  id          String        @id @default(cuid())
  tenantId    String
  clientId    String?
  name        String
  description String?
  status      ProjectStatus @default(DRAFT)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  tenant                 Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client                 Client?                 @relation(fields: [clientId], references: [id], onDelete: SetNull)
  questionnaireTemplates QuestionnaireTemplate[]
  questionnaireSubmissions QuestionnaireSubmission[]
  answers                Answer[]
  assets                 Asset[]
  workflows              Workflow[]

  @@unique([tenantId, name])
  @@map("projects")
}

// Questionnaire templates within a tenant
model QuestionnaireTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  projectId   String?
  name        String
  description String?
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  tenant       Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project      Project?                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions    Question[]
  submissions  QuestionnaireSubmission[]

  @@unique([tenantId, name, version])
  @@map("questionnaire_templates")
}

// Questionnaire submissions within a tenant
model QuestionnaireSubmission {
  id          String             @id @default(cuid())
  tenantId    String
  projectId   String?
  templateId  String
  status      SubmissionStatus   @default(DRAFT)
  submittedAt DateTime?
  lockedAt    DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  // Relations
  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project?              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  Answer[]

  @@unique([tenantId, projectId, templateId]) // One submission per project-template combination
  @@map("questionnaire_submissions")
}

// Questions within a questionnaire template
model Question {
  id          String       @id @default(cuid())
  templateId  String
  type        QuestionType
  title       String
  description String?
  config      Json? // Type-specific configuration (options, validation rules, conditions, file constraints, etc.)
  order       Int
  required    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  template QuestionnaireTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  answers  Answer[]
  assets   Asset[]

  @@unique([templateId, order]) // Ensure unique ordering per template
  @@map("questions")
}

// Answers to questions within a tenant
model Answer {
  id            String    @id @default(cuid())
  tenantId      String
  submissionId  String
  questionId    String
  projectId     String?
  value         Json // Flexible value storage (string, number, array, object)
  submittedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  submission  QuestionnaireSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question    Question                @relation(fields: [questionId], references: [id], onDelete: Cascade)
  project     Project?                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([submissionId, questionId]) // One answer per question per submission
  @@map("answers")
}

// Assets (files/documents) within a tenant
model Asset {
  id         String   @id @default(cuid())
  tenantId   String
  projectId  String?
  questionId String?
  name       String
  fileName   String
  mimeType   String
  size       Int
  checksum   String // SHA-256 hash for integrity
  storageKey String // Cloud storage key/path
  url        String? // Public URL if applicable
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relations
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  question Question? @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("assets")
}

// Workflows within a tenant
model Workflow {
  id          String         @id @default(cuid())
  tenantId    String
  projectId   String
  name        String
  description String?
  source      WorkflowSource @default(MANUAL) // MANUAL or AI_GENERATED
  status      WorkflowStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  phases  Phase[]

  @@unique([tenantId, projectId]) // One workflow per project for now
  @@map("workflows")
}

// Phases within a workflow
model Phase {
  id          String      @id @default(cuid())
  workflowId  String
  name        String
  description String?
  order       Int
  status      PhaseStatus @default(PENDING)
  startDate   DateTime?
  endDate     DateTime?
  metadata    Json? // Additional phase-specific data
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relations
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tasks    Task[]

  @@map("phases")
}

// Tasks within a phase
model Task {
  id          String     @id @default(cuid())
  phaseId     String
  title       String
  description String?
  order       Int
  status      TaskStatus @default(PENDING)
  priority    Priority   @default(MEDIUM)
  assigneeId  String? // User ID who owns this task
  dueDate     DateTime?
  completedAt DateTime?
  metadata    Json? // Additional task-specific data
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  phase    Phase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  assignee User? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@map("tasks")
}

// Progress tracking (rollups and snapshots)
model Progress {
  id         String         @id @default(cuid())
  entityType ProgressEntity // PROJECT, PHASE, or TASK
  entityId   String // ID of the entity being tracked
  status     ProgressStatus @default(NOT_STARTED)
  percentage Float          @default(0) // 0-100
  snapshotAt DateTime       @default(now())
  metadata   Json? // Additional progress data
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("progress")
}

// Enums
enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum QuestionType {
  TEXT
  TEXTAREA
  SELECT
  MULTI_SELECT
  FILE_UPLOAD
  URL
  DATE
  NUMBER
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

enum WorkflowSource {
  MANUAL
  AI_GENERATED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProgressEntity {
  PROJECT
  PHASE
  TASK
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}
