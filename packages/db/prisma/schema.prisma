generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model account {
  id           String    @id
  accountId    String
  providerId   String
  userId       String
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now())
  user         user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ai_rate_limits {
  id          String   @id
  tenantId    String
  scope       String
  window      String
  windowStart DateTime
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  tenants     tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, scope, window, windowStart])
}

model ai_workflow_generations {
  id                        String                    @id
  tenantId                  String
  submissionId              String
  projectId                 String
  status                    String
  workflowId                String?
  provider                  String?
  promptId                  String?
  promptVersion             String?
  requestId                 String?
  errorCode                 String?
  errorMessage              String?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime
  projects                  projects                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questionnaire_submissions questionnaire_submissions @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  tenants                   tenants                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflows                 workflows?                @relation(fields: [workflowId], references: [id])

  @@unique([tenantId, submissionId])
}

model answers {
  id                        String                    @id
  tenantId                  String
  submissionId              String
  questionId                String
  projectId                 String?
  value                     Json
  submittedAt               DateTime?
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime
  projects                  projects?                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions                 questions                 @relation(fields: [questionId], references: [id], onDelete: Cascade)
  questionnaire_submissions questionnaire_submissions @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  tenants                   tenants                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets                    assets[]

  @@unique([submissionId, questionId])
}

model asset_versions {
  id         String   @id
  assetId    String
  version    Int
  checksum   String
  size       Int
  storageKey String
  changeLog  String?
  createdAt  DateTime @default(now())
  assets     assets   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, version])
}

model assets {
  id             String           @id
  tenantId       String
  projectId      String?
  questionId     String?
  answerId       String?
  workflowId     String?
  phaseId        String?
  taskId         String?
  uploaderId     String
  name           String
  fileName       String
  mimeType       String
  size           Int
  checksum       String
  storageKey     String
  accessLevel    AssetAccessLevel @default(TENANT)
  url            String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  asset_versions asset_versions[]
  answers        answers?         @relation(fields: [answerId], references: [id], onDelete: Cascade)
  phases         phases?          @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  projects       projects?        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questions      questions?       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  tasks          tasks?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tenants        tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          users            @relation(fields: [uploaderId], references: [id])
  workflows      workflows?       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model clients {
  id        String     @id
  tenantId  String
  name      String
  email     String?
  phone     String?
  company   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime
  tenants   tenants    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projects  projects[]
}

model phases {
  id               String         @id
  workflowId       String
  name             String
  intent           PhaseIntent    @default(CUSTOM)
  description      String?
  order            Int
  status           PhaseStatus    @default(PENDING)
  startDate        DateTime?
  endDate          DateTime?
  source           WorkflowSource @default(MANUAL)
  isManuallyEdited Boolean        @default(false)
  lastEditedById   String?
  lastEditedAt     DateTime?
  metadata         Json?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  assets           assets[]
  users            users?         @relation(fields: [lastEditedById], references: [id])
  workflows        workflows      @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tasks            tasks[]
}

model progress {
  id         String         @id
  entityType ProgressEntity
  entityId   String
  status     ProgressStatus @default(NOT_STARTED)
  percentage Float          @default(0)
  snapshotAt DateTime       @default(now())
  metadata   Json?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime
}

model projects {
  id                        String                      @id
  tenantId                  String
  clientId                  String?
  name                      String
  description               String?
  status                    ProjectStatus               @default(DRAFT)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  ai_workflow_generations   ai_workflow_generations[]
  answers                   answers[]
  assets                    assets[]
  clients                   clients?                    @relation(fields: [clientId], references: [id])
  tenants                   tenants                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questionnaire_submissions questionnaire_submissions[]
  questionnaire_templates   questionnaire_templates[]
  workflow_snapshots        workflow_snapshots[]
  workflows                 workflows[]

  @@unique([tenantId, name])
}

model questionnaire_submissions {
  id                      String                    @id
  tenantId                String
  projectId               String?
  templateId              String
  status                  SubmissionStatus          @default(DRAFT)
  submittedAt             DateTime?
  lockedAt                DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  ai_workflow_generations ai_workflow_generations[]
  answers                 answers[]
  projects                projects?                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questionnaire_templates questionnaire_templates   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tenants                 tenants                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, templateId])
}

model questionnaire_templates {
  id                        String                      @id
  tenantId                  String
  projectId                 String?
  name                      String
  description               String?
  version                   Int                         @default(1)
  isActive                  Boolean                     @default(true)
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  questionnaire_submissions questionnaire_submissions[]
  projects                  projects?                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenants                   tenants                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  questions                 questions[]

  @@unique([tenantId, name, version])
}

model questions {
  id                      String                  @id
  templateId              String
  type                    QuestionType
  title                   String
  description             String?
  config                  Json?
  order                   Int
  required                Boolean                 @default(false)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime
  answers                 answers[]
  assets                  assets[]
  questionnaire_templates questionnaire_templates @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
}

model roles {
  id        String   @id
  tenantId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime
  tenants   tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users     users[]  @relation("user_roles")

  @@unique([tenantId, name])
}

model session {
  id        String   @id
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  token     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model task_dependencies {
  id                                        String @id
  fromTaskId                                String
  toTaskId                                  String
  tasks_task_dependencies_fromTaskIdTotasks tasks  @relation("task_dependencies_fromTaskIdTotasks", fields: [fromTaskId], references: [id], onDelete: Cascade)
  tasks_task_dependencies_toTaskIdTotasks   tasks  @relation("task_dependencies_toTaskIdTotasks", fields: [toTaskId], references: [id], onDelete: Cascade)

  @@unique([fromTaskId, toTaskId])
  @@index([toTaskId])
}

model tasks {
  id                                                    String              @id
  phaseId                                               String
  title                                                 String
  description                                           String?
  order                                                 Int
  status                                                TaskStatus          @default(PENDING)
  priority                                              Priority            @default(MEDIUM)
  assigneeId                                            String?
  dueDate                                               DateTime?
  completedAt                                           DateTime?
  estimatedDurationDays                                 Int?
  isMilestone                                           Boolean             @default(false)
  source                                                WorkflowSource      @default(MANUAL)
  isManuallyEdited                                      Boolean             @default(false)
  lastEditedById                                        String?
  lastEditedAt                                          DateTime?
  metadata                                              Json?
  createdAt                                             DateTime            @default(now())
  updatedAt                                             DateTime
  assets                                                assets[]
  task_dependencies_task_dependencies_fromTaskIdTotasks task_dependencies[] @relation("task_dependencies_fromTaskIdTotasks")
  task_dependencies_task_dependencies_toTaskIdTotasks   task_dependencies[] @relation("task_dependencies_toTaskIdTotasks")
  users_tasks_assigneeIdTousers                         users?              @relation("tasks_assigneeIdTousers", fields: [assigneeId], references: [id])
  users_tasks_lastEditedByIdTousers                     users?              @relation("tasks_lastEditedByIdTousers", fields: [lastEditedById], references: [id])
  phases                                                phases              @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model tenants {
  id                        String                      @id
  name                      String
  slug                      String                      @unique
  metadata                  Json?
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  ai_rate_limits            ai_rate_limits[]
  ai_workflow_generations   ai_workflow_generations[]
  answers                   answers[]
  assets                    assets[]
  clients                   clients[]
  projects                  projects[]
  questionnaire_submissions questionnaire_submissions[]
  questionnaire_templates   questionnaire_templates[]
  roles                     roles[]
  users                     users[]
  workflow_snapshots        workflow_snapshots[]
  workflows                 workflows[]
}

model user {
  id            String    @id
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
  account       account[]
  session       session[]
}

model users {
  id                                        String               @id
  tenantId                                  String?
  role                                      UserRole             @default(CLIENT)
  email                                     String
  firstName                                 String?
  lastName                                  String?
  avatarUrl                                 String?
  createdAt                                 DateTime             @default(now())
  updatedAt                                 DateTime
  assets                                    assets[]
  phases                                    phases[]
  tasks_tasks_assigneeIdTousers             tasks[]              @relation("tasks_assigneeIdTousers")
  tasks_tasks_lastEditedByIdTousers         tasks[]              @relation("tasks_lastEditedByIdTousers")
  tenants                                   tenants?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflow_snapshots                        workflow_snapshots[]
  workflows_workflows_aiApprovedByIdTousers workflows[]          @relation("workflows_aiApprovedByIdTousers")
  workflows_workflows_lastEditedByIdTousers workflows[]          @relation("workflows_lastEditedByIdTousers")
  userRoles                                 roles[]              @relation("user_roles")

  @@unique([tenantId, email])
}

model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime

  @@unique([identifier, value])
}

model workflow_snapshot_phases {
  id                      String                    @id
  snapshotId              String
  sourcePhaseId           String
  name                    String
  intent                  PhaseIntent               @default(CUSTOM)
  description             String?
  order                   Int
  createdAt               DateTime                  @default(now())
  workflow_snapshots      workflow_snapshots        @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  workflow_snapshot_tasks workflow_snapshot_tasks[]
}

model workflow_snapshot_progress {
  id                 String             @id
  snapshotId         String             @unique
  totalTasks         Int                @default(0)
  completedTasks     Int                @default(0)
  perPhase           Json?
  updatedAt          DateTime
  workflow_snapshots workflow_snapshots @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
}

model workflow_snapshot_tasks {
  id                       String                   @id
  snapshotPhaseId          String
  sourceTaskId             String
  title                    String
  description              String?
  order                    Int
  priority                 Priority                 @default(MEDIUM)
  estimatedDurationDays    Int?
  isMilestone              Boolean                  @default(false)
  createdAt                DateTime                 @default(now())
  workflow_snapshot_phases workflow_snapshot_phases @relation(fields: [snapshotPhaseId], references: [id], onDelete: Cascade)
}

model workflow_snapshots {
  id                         String                      @id
  tenantId                   String
  projectId                  String
  workflowId                 String
  version                    Int                         @default(1)
  isCurrent                  Boolean                     @default(true)
  dependencies               Json?
  timeline                   Json?
  createdAt                  DateTime                    @default(now())
  createdById                String
  workflow_snapshot_phases   workflow_snapshot_phases[]
  workflow_snapshot_progress workflow_snapshot_progress?
  users                      users                       @relation(fields: [createdById], references: [id], onDelete: Cascade)
  projects                   projects                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenants                    tenants                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workflows                  workflows                   @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId, isCurrent])
  @@index([tenantId, projectId])
}

model workflows {
  id                                    String                    @id
  tenantId                              String
  projectId                             String
  name                                  String
  description                           String?
  source                                WorkflowSource            @default(MANUAL)
  status                                WorkflowStatus            @default(DRAFT)
  isManuallyEdited                      Boolean                   @default(false)
  lastEditedById                        String?
  lastEditedAt                          DateTime?
  createdAt                             DateTime                  @default(now())
  updatedAt                             DateTime
  aiApprovalNotes                       String?
  aiApprovedAt                          DateTime?
  aiApprovedById                        String?
  aiGeneratedFromSubmissionId           String?
  ai_workflow_generations               ai_workflow_generations[]
  assets                                assets[]
  phases                                phases[]
  workflow_snapshots                    workflow_snapshots[]
  users_workflows_aiApprovedByIdTousers users?                    @relation("workflows_aiApprovedByIdTousers", fields: [aiApprovedById], references: [id])
  users_workflows_lastEditedByIdTousers users?                    @relation("workflows_lastEditedByIdTousers", fields: [lastEditedById], references: [id])
  projects                              projects                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenants                               tenants                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, projectId])
}

enum AssetAccessLevel {
  ADMIN_ONLY
  TENANT
  PUBLIC
}

enum UserRole {
  CLIENT
  ADMIN
}

enum PhaseIntent {
  DISCOVERY
  DESIGN
  BUILD
  TEST
  DEPLOY
  MAINTENANCE
  CUSTOM
}

enum PhaseStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProgressEntity {
  PROJECT
  PHASE
  TASK
}

enum ProgressStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum QuestionType {
  TEXT
  TEXTAREA
  SELECT
  MULTI_SELECT
  FILE_UPLOAD
  URL
  DATE
  NUMBER
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
  CANCELLED
}

enum WorkflowSource {
  MANUAL
  AI_GENERATED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}
