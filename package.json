{
  "name": "horizon",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "turbo build",
    "dev": "concurrently \"bun run dev:proxy\" \"bun run dev:web\"",
    "dev:proxy": "bun --filter=@horizon/proxy dev",
    "dev:web": "bun --filter=@horizon/web dev -- --port 3001",
    "dev:all": "turbo dev",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "lint:staged": "eslint --fix --config .eslintrc.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "prepare": "husky",
    "db:generate": "bun --filter=@horizon/db prisma:generate",
    "postinstall": "bun run db:generate"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.2.21",
  "devDependencies": {
    "concurrently": "^8.2.0",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.6.3"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  }
}
